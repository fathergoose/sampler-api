{
  "plugins": ["@trivago/prettier-plugin-sort-imports", "prettier-plugin-embed", "prettier-plugin-sql"],
  "embededSqlTags": ["sql"],
  "language": "postgresql",
  "keywordCase": "upper",
  "importOrder": [
    "<THIRD_PARTY_MODULES>",
    "^@src/[^/]+(/.*)?$",
    "^\\.(?!.*\\.css$).*$",
    "^.+\\.css$"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderCaseInsensitive": true,
  "singleQuote": true,
  "printWidth": 80,
  "tabWidth": 2
}
